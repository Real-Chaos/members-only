<header class="app-header">
    <nav>
        <div class="logo">
            <h1><a href="/">Members Only</a></h1>
        </div>
        <ul>
            <% if(user) { %>
                <li><a href="/new-message"><i class="fas fa-envelope"></i> Message</a></li>
                <% if(!user.member) { %>
                    <li><a href="/new-member"><i class="fas fa-heart"></i> Become Member</a></li>
                <% } %>
                <% if(!user.admin) { %>
                    <li><a href="/new-admin"><i class="fas fa-fire"></i> Become Admin</a></li>
                <% } %>
                <li><a href="/log-out"><i class="fas fa-sign-out-alt"></i> Log Out</a></li>
            <% } else { %>
                <li><a href="/log-in"><i class="fas fa-sign-in-alt"></i> Log In</a></li>
                <li><a href="/sign-up"><i class="fas fa-user-plus"></i> Sign Up</a></li>
            <% } %>
        </ul>
    </nav>
</header>